" ========================================================
" Base Settings
" ========================================================
set scrolloff=10
set relativenumber
set showmode
set showcmd

" Remove sound when invalid input
set visualbell

" Case-insensitive searching UNLESS \C or one or more capital letters
set ignorecase
set smartcase
set incsearch
set hlsearch

" Map leader key to space-bar
let mapleader = " "

" Leader key timeout
set notimeout

" Use system clipboard
set clipboard+=unnamedplus

" ========================================================
" Plugin Settings (IdeaVim loads plugins automatically)
" ========================================================
set surround
set highlightedyank
set sneak

" ========================================================
" Key mappings
" ========================================================

" Center cursor on page up/down
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Clear search highlighting when pressing ESC
nnoremap <ESC> :nohlsearch<CR><ESC>

" Pane navigation (use Ctrl for reliability)
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l
nnoremap <C-k> <C-w>k
nnoremap <C-j> <C-w>j

" Easy visual indentation
vnoremap < <gv
vnoremap > >gv

" Popup navigation
inoremap <C-n> :action PopupMenu-selectNext<CR>
inoremap <C-p> :action PopupMenu-selectPrev<CR>

" ========================================================
" Leader commands
" ========================================================

" Comment 
nnoremap <leader>cl :action CommentByLineComment<CR>

" Open Project Tool Window (instead of NERDTree)
nnoremap <C-n> :action ActivateProjectToolWindow<CR>

" Folding
nnoremap <leader>zc :action CollapseAllRegions<CR>
nnoremap <leader>zo :action ExpandAllRegions<CR>

" Display options
nnoremap <leader>dd :action ToggleDistractionFreeMode<CR>
nnoremap <leader>dz :action ToggleZenMode<CR>
nnoremap <leader>df :action ToggleFullScreen<CR>

" Actions
nnoremap <leader>ca :action ShowIntentionActions<CR>

" Search
nnoremap <leader>sf :action GotoFile<CR>
nnoremap <leader>s. :action RecentFiles<CR>
nnoremap <leader>sg :action FindInPath<CR>
nnoremap <leader>ss :action GoToSymbol<CR>
nnoremap <leader>sa :action Search<CR>

" Refactoring
nnoremap <leader>rn :action RenameElement<CR>
nnoremap <leader>rm :action ExtractMethod<CR>
nnoremap <leader>rv :action IntroduceVariable<CR>
nnoremap <leader>rf :action IntroduceField<CR>
nnoremap <leader>rs :action ChangeSignature<CR>
nnoremap <leader>rr :action Refactorings.QuickListPopupAction<CR>

" Go to code
nnoremap gd :action GotoDeclaration<CR>
nnoremap gr :action ShowUsages<CR>
nnoremap gt :action GotoTypeDeclaration<CR>
nnoremap gi :action GotoImplementation<CR>

" Git windows
nnoremap <leader>vc :action CheckinProject<CR>
nnoremap <leader>vs :action ActivateVersionControlToolWindow<CR>
nnoremap <leader>vb :action Git.Branches<CR>

" Error diagnostics
nnoremap ]d :action GotoNextError<CR>
nnoremap [d :action GotoPreviousError<CR>

" Terminal
nnoremap <C-t> :action ActivateTerminalToolWindow<CR>

" Hover Info
nnoremap K :action ShowHoverInfo<CR>

" Close all tool windows
nnoremap <leader><leader> :action HideAllWindows<CR>

" Go to .ideavimrc
nnoremap <leader>; :e ~/.ideavimrc<CR>

" ========================================================
" Harpoon-style bookmarks
" ========================================================
nnoremap <leader>a :action ToggleBookmarkWithMnemonic<CR>
nnoremap <leader>m :action ToggleBookmark<CR>
nnoremap <leader>h :action ShowBookmarks<CR>
nnoremap <A-a> :action GotoBookmark1<CR>
nnoremap <A-s> :action GotoBookmark2<CR>
nnoremap <A-d> :action GotoBookmark3<CR>
nnoremap <A-f> :action GotoBookmark4<CR>
nnoremap <A-g> :action GotoBookmark5<CR>
