{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}",
    "format-icons": {
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}  {volume}% ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Όυν  {icon} ΎΛΦ {format_source}",
    "format-muted": "≤░ΜΡ {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "Ό╣β",
      "headset": "Ό╣β",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format-wifi": "ΎΘτ {essid}",
    "format-ethernet": "{ipaddr}/{cidr} ΎΘτ",
    "tooltip-format": "{ifname} via {gwaddr} ({signalStrength}%)",
    "format-linked": "{ifname} (No IP) ΎηΨ",
    "format-disconnected": "Disconnected έγι",
    "on-click": "nm-connection-editor"
  },
  "cpu": {
    "format": "ΎΜδ {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "ΎΔΚ {}%",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "≤░ΓΚ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
 "clock": {
    "format": "{:%H:%M | %e %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  }
}
